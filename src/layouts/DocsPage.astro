---
import { localizedPath, type Locale } from "../i18n";
import { getSiteCopy } from "../site-content";
import SiteLayout from "./SiteLayout.astro";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  pagePath: string;
}

const { title, description, locale, pagePath } = Astro.props;
const copy = getSiteCopy(locale);
const pageTitle = title === copy.docs.titleSuffix ? title : `${title} | ${copy.docs.titleSuffix}`;
---

<SiteLayout
  title={pageTitle}
  description={description}
  locale={locale}
  pagePath={pagePath}
>
  <section class="page-hero docs-page-hero">
    <h1>{title}</h1>
    <p>{description}</p>
    <div class="tag-row">
      <a class="tag" href={localizedPath("/docs/", locale)}>{copy.docsNav.overview}</a>
      <a class="tag" href={localizedPath("/docs/getting-started/", locale)}>
        {copy.docsNav.gettingStarted}
      </a>
      <a class="tag" href={localizedPath("/docs/install/", locale)}>{copy.docsNav.install}</a>
      <a class="tag" href={localizedPath("/docs/package-discovery/", locale)}>
        {copy.docsNav.packageDiscovery}
      </a>
    </div>
  </section>

  <section class="section docs-content-section">
    <article class="card docs-content-card">
      <slot />
    </article>
  </section>
</SiteLayout>
