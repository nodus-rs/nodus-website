---
import { getLocaleFromPathname, localizedPath } from "../i18n";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getSiteCopy } from "../site-content";

const locale = getLocaleFromPathname(Astro.url.pathname);
const copy = getSiteCopy(locale);
const notFound = copy.notFound;
---

<SiteLayout
  title={notFound.title}
  description={notFound.description}
  locale={locale}
>
  <section class="page-hero">
    <span class="eyebrow">404</span>
    <h1>{notFound.heroTitle}</h1>
    <p>{notFound.heroDescription}</p>
    <div class="hero-actions">
      <a class="button button-primary" href={localizedPath("/docs/", locale)}>{copy.layout.docs}</a>
      <a class="button button-secondary" href={localizedPath("/packages/", locale)}>{copy.layout.addPackage}</a>
      <a class="button button-secondary" href={localizedPath("/install/", locale)}>{copy.layout.install}</a>
    </div>
  </section>
</SiteLayout>
