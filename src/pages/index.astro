---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../site-config";

const packages = (await getCollection("packages"))
  .filter((entry) => entry.data.featured)
  .slice(0, 3);
---

<SiteLayout
  title="Nodus | Add agent packages to your repo with one command"
  description="Nodus installs repo-scoped agent packages from GitHub or local paths, locks exact revisions, and writes the runtime files your tools actually use."
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Repo-scoped AI tooling • exact lockfiles • adapter-aware sync</span>
      <h1>Install Nodus fast. Keep your repo outputs exact.</h1>
      <p>
        A CLI package manager for agent tooling that locks revisions and writes only the files
        your adapters need.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteConfig.installPath}>Install guide</a>
        <a class="button button-secondary" href={siteConfig.packagesPath}>Browse packages</a>
      </div>

      <div class="hero-meta hero-meta-tags">
        <span>Latest {siteConfig.latestVersion}</span>
        <span>Codex</span>
        <span>Claude</span>
        <span>Cursor</span>
        <span>Copilot</span>
        <span>Agents</span>
        <span>OpenCode</span>
      </div>
    </div>

    <div class="hero-stack">
      <div class="install-console">
        <div class="install-console-header">
          <div class="install-tabs" aria-hidden="true">
            <span class="install-tab active">macOS / Linux</span>
            <span class="install-tab">PowerShell</span>
          </div>
          <a class="install-link" href={siteConfig.installPath}>All install options</a>
        </div>
        <pre class="install-command"><code>{siteConfig.installUnixCommand}</code></pre>
        <div class="secondary-command">
          <span class="secondary-command-label">Windows</span>
          <code>{siteConfig.installWindowsCommand}</code>
        </div>
      </div>

      <div class="command-card command-card-compact">
        <div class="command-card-header">
          <strong>Then run</strong>
          <span>First repo setup</span>
        </div>
        <pre><code>nodus add acme/team-pack --adapter codex
nodus doctor</code></pre>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">Why it works</span>
        <h2>Three steps. Reviewable output.</h2>
      </div>
      <p class="section-intro">
        Nodus keeps the flow small: add a package, lock the source, sync the adapter files.
      </p>
    </div>

    <div class="grid-3">
      <article class="step-card">
        <span class="pill">01</span>
        <h3>Add from GitHub or local paths</h3>
        <p>Pull in packages without changing how the rest of the repo works.</p>
        <code class="inline-command">nodus add org/pkg --adapter codex</code>
      </article>
      <article class="step-card">
        <span class="pill">02</span>
        <h3>Lock exact revisions</h3>
        <p>Keep teammates and CI on the same package graph with deterministic inputs.</p>
        <code class="inline-command">nodus sync --locked</code>
      </article>
      <article class="step-card">
        <span class="pill">03</span>
        <h3>Write adapter-specific outputs</h3>
        <p>Generate only the runtime files each tool actually reads inside the repo.</p>
        <code class="inline-command">.codex/ .claude/ .github/</code>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">Discovery</span>
        <h2>Start with featured packages</h2>
      </div>
      <a class="button button-secondary" href={siteConfig.packagesPath}>Browse all packages</a>
    </div>

    <div class="packages-grid">
      {
        packages.map((entry) => (
          <article class="package-card">
            <div class="pill-row">
              <span class="pill">Featured</span>
              <span class="tag">{entry.data.latestVersion}</span>
            </div>
            <h3><a href={`/packages/${entry.slug}/`}>{entry.data.name}</a></h3>
            <p>{entry.data.summary}</p>
            <div class="tag-row">
              {entry.data.adapters.slice(0, 3).map((adapter) => <span class="tag">{adapter}</span>)}
            </div>
            <div class="package-meta">
              <span>{entry.data.repo}</span>
              <span>{entry.data.maintainer}</span>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>
