---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../site-config";

const packages = (await getCollection("packages"))
  .filter((entry) => entry.data.featured)
  .slice(0, 3);
---

<SiteLayout
  title="Nodus | Add agent packages to your repo with one command"
  description="Nodus installs repo-scoped agent packages from GitHub or local paths, locks exact revisions, and writes the runtime files your tools actually use."
>
  <section class="hero">
    <div>
      <span class="eyebrow">Local-first workflow • exact lockfiles • multi-adapter outputs</span>
      <h1>Add agent packages to your repo with one command.</h1>
      <p>
        Nodus installs skills, agents, rules, and commands from GitHub or local paths,
        locks exact revisions, and writes the runtime files your tools actually use.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteConfig.installPath}>Install Nodus</a>
        <a class="button button-secondary" href={siteConfig.docsPath}>Read the docs</a>
      </div>

      <div class="hero-meta">
        <span>Latest release: {siteConfig.latestVersion}</span>
        <span>Adapters: Codex, Claude, Cursor, Copilot, Agents, OpenCode</span>
      </div>
    </div>

    <div class="hero-grid">
      <div class="command-card">
        <div class="command-card-header">
          <strong>Quick start</strong>
          <div class="traffic-lights" aria-hidden="true">
            <span />
            <span />
            <span />
          </div>
        </div>
        <pre><code>{siteConfig.installUnixCommand}
nodus add nodus-rs/nodus --adapter codex
nodus doctor</code></pre>
      </div>

      <div class="command-card">
        <div class="command-card-header">
          <strong>What Nodus manages</strong>
          <span>Generated output</span>
        </div>
        <div class="command-list">
          <div class="command-row">
            <code>.codex/skills/&lt;skill&gt;_&lt;source&gt;/</code>
            <span>Codex runtime files</span>
          </div>
          <div class="command-row">
            <code>.claude/skills/&lt;skill&gt;_&lt;source&gt;/</code>
            <span>Claude package output</span>
          </div>
          <div class="command-row">
            <code>.github/agents/&lt;agent&gt;_&lt;source&gt;.agent.md</code>
            <span>GitHub agent assets</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">How it works</span>
        <h2>Fast, deterministic, and built for real repos</h2>
      </div>
      <p class="section-intro">
        Nodus keeps the package-manager shape simple: add a dependency, lock the exact
        source revision, and materialize only the runtime files your chosen adapters need.
      </p>
    </div>

    <div class="grid-3">
      <article class="step-card">
        <span class="pill">01</span>
        <h3>Add from GitHub, Git, or a local path</h3>
        <p>
          Pull in public packages, private repos, or local checkouts without changing your
          workflow or forcing a registry migration first.
        </p>
      </article>

      <article class="step-card">
        <span class="pill">02</span>
        <h3>Pin exactly what you asked for</h3>
        <p>
          Nodus records the dependency in <code>nodus.toml</code>, resolves the version,
          and writes an exact lockfile so CI and teammates stay consistent.
        </p>
      </article>

      <article class="step-card">
        <span class="pill">03</span>
        <h3>Generate only the runtime files your tools use</h3>
        <p>
          Output lands in adapter-specific folders such as <code>.codex/</code>,
          <code>.claude/</code>, <code>.cursor/</code>, or <code>.github/</code>.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">Core capabilities</span>
        <h2>CLI-first, not workflow-heavy</h2>
      </div>
      <p class="section-intro">
        Most repos only need a handful of commands. Nodus is designed for quick,
        transactional operations rather than a long-running control plane.
      </p>
    </div>

    <div class="grid-3">
      <article class="feature-card">
        <h3>Repo-scoped package management</h3>
        <p>
          Install packages into the current repo, lock them, and sync managed files without
          touching unrelated local state.
        </p>
      </article>
      <article class="feature-card">
        <h3>Adapter-aware outputs</h3>
        <p>
          Generate runtime files for Codex, Claude, Cursor, Copilot, Agents, and OpenCode
          from one manifest.
        </p>
      </article>
      <article class="feature-card">
        <h3>Predictable CI and teammate sync</h3>
        <p>
          Use <code>nodus sync --locked</code> or <code>nodus sync --frozen</code> to
          keep repo automation stable and reviewable.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">Discovery</span>
        <h2>Start with featured packages</h2>
      </div>
      <a class="button button-secondary" href={siteConfig.packagesPath}>Browse all packages</a>
    </div>

    <div class="packages-grid">
      {
        packages.map((entry) => (
          <article class="package-card">
            <div class="pill-row">
              <span class="pill">Featured</span>
              <span class="tag">{entry.data.latestVersion}</span>
            </div>
            <h3><a href={`/packages/${entry.slug}/`}>{entry.data.name}</a></h3>
            <p>{entry.data.summary}</p>
            <div class="tag-row">
              {entry.data.adapters.slice(0, 3).map((adapter) => <span class="tag">{adapter}</span>)}
            </div>
            <div class="package-meta">
              <span>{entry.data.repo}</span>
              <span>{entry.data.maintainer}</span>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="grid-2">
      <article class="card">
        <span class="eyebrow">Install</span>
        <h2>Use a clean public install URL</h2>
        <p>
          The site publishes stable installer endpoints so the public command stays clean
          even if release infrastructure changes behind the scenes later.
        </p>
        <pre><code>{siteConfig.installUnixCommand}</code></pre>
      </article>

      <article class="card">
        <span class="eyebrow">Docs</span>
        <h2>Get productive quickly</h2>
        <p>
          Start with install, add your first package, then validate with <code>nodus doctor</code>.
          The docs cover manifest shape, update flows, and common package-management tasks.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/docs/getting-started/">Getting started</a>
          <a class="button button-secondary" href="/install/">Install options</a>
        </div>
      </article>
    </div>
  </section>
</SiteLayout>
