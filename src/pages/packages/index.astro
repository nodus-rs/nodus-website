---
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Add a package with Nodus"
  description="Normalize a package source into the exact nodus add command you should run."
>
  <section class="page-hero">
    <span class="eyebrow">Add package</span>
    <h1>Paste a package source. Get the command.</h1>
    <p>
      Use GitHub shorthand, a repo URL, or a full Git URL. Nodus normalizes the source and
      prints the exact <code>nodus add</code> command.
    </p>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">Command generator</span>
        <h2>Translate a source into a runnable command.</h2>
      </div>
      <p class="section-intro">
        The form keeps the rules small: GitHub sources normalize to shorthand, generic Git URLs stay intact, and the adapter flag is optional.
      </p>
    </div>

    <div class="grid-2 tool-grid">
      <article class="card command-tool">
        <div class="tool-form">
          <label class="field-label" for="package-source">Package source</label>
          <input
            id="package-source"
            type="text"
            placeholder="https://github.com/nodus-rs/nodus or nodus-rs/nodus"
            autocomplete="off"
            spellcheck="false"
          />

          <label class="field-label" for="adapter-select">Adapter (optional)</label>
          <select id="adapter-select">
            <option value="">Auto-detect in repo</option>
            <option value="agents">agents</option>
            <option value="claude">claude</option>
            <option value="codex">codex</option>
            <option value="copilot">copilot</option>
            <option value="cursor">cursor</option>
            <option value="opencode">opencode</option>
          </select>

          <p class="muted tool-note" id="source-note">
            GitHub links normalize to <code>owner/repo</code>. Generic Git URLs stay unchanged.
          </p>
          <p class="validation-message" id="source-error" hidden></p>

          <div class="command-output" id="command-output" hidden>
            <div class="command-card-header">
              <strong>Run this in your repo</strong>
              <button class="button button-secondary button-inline" id="copy-command" type="button">Copy</button>
            </div>
            <pre><code id="command-preview">nodus add nodus-rs/nodus</code></pre>
          </div>

          <p class="muted tool-note">
            If Nodus cannot detect your repo adapter yet, append <code>--adapter</code> or pick one above.
          </p>
        </div>
      </article>

      <article class="card">
        <span class="eyebrow">Accepted inputs</span>
        <h2>Supported source shapes</h2>
        <div class="tool-examples">
          <div class="command-row">
            <code>nodus-rs/nodus</code>
            <span>GitHub shorthand</span>
          </div>
          <div class="command-row">
            <code>https://github.com/nodus-rs/nodus</code>
            <span>GitHub repo URL</span>
          </div>
          <div class="command-row">
            <code>git@github.com:nodus-rs/nodus.git</code>
            <span>GitHub SSH URL</span>
          </div>
          <div class="command-row">
            <code>https://git.example.com/team/playbook.git</code>
            <span>Generic Git URL</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <span class="eyebrow">How it behaves</span>
        <h2>Normalization is strict where it matters.</h2>
      </div>
      <p class="section-intro">
        Users get one command shape, and the page explains why a source is accepted or rejected instead of hiding the rules.
      </p>
    </div>

    <div class="grid-3">
      <article class="step-card">
        <span class="pill">01</span>
        <h3>Recognize GitHub references</h3>
        <p>Short forms, repo URLs, and SSH URLs all collapse to the same <code>owner/repo</code> form.</p>
      </article>
      <article class="step-card">
        <span class="pill">02</span>
        <h3>Leave generic Git URLs alone</h3>
        <p>Non-GitHub Git endpoints stay as-is, which keeps enterprise mirrors and private hosts usable.</p>
      </article>
      <article class="step-card">
        <span class="pill">03</span>
        <h3>Expose the adapter flag explicitly</h3>
        <p>Users can copy one command, then add a specific adapter only when auto-detection is not enough.</p>
      </article>
    </div>
  </section>

  <script>
    const sourceInput = document.querySelector("#package-source");
    const adapterSelect = document.querySelector("#adapter-select");
    const output = document.querySelector("#command-output");
    const preview = document.querySelector("#command-preview");
    const error = document.querySelector("#source-error");
    const copyButton = document.querySelector("#copy-command");

    const isOwnerRepo = (value: string) => /^[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+$/.test(value);

    const normalizeGitHubPath = (value: string) => {
      const trimmed = value.trim().replace(/\.git$/i, "").replace(/\/+$/g, "");

      if (isOwnerRepo(trimmed)) {
        return trimmed;
      }

      const sshMatch = trimmed.match(/^git@github\.com:([^/]+)\/([^/]+)$/i);
      if (sshMatch) {
        return `${sshMatch[1]}/${sshMatch[2]}`;
      }

      try {
        const url = new URL(trimmed);
        if (url.hostname !== "github.com") {
          return null;
        }

        const [owner, repo] = url.pathname.replace(/^\/+/, "").split("/");
        if (!owner || !repo) {
          return null;
        }

        return `${owner}/${repo.replace(/\.git$/i, "")}`;
      } catch {
        return null;
      }
    };

    const isGenericGitUrl = (value: string) => {
      if (/^(git@|ssh:\/\/|https?:\/\/)/i.test(value) === false) {
        return false;
      }

      try {
        const url = value.startsWith("git@") ? null : new URL(value);
        return url ? Boolean(url.hostname) : true;
      } catch {
        return /^git@[^:]+:.+/.test(value);
      }
    };

    const getNormalizedSource = (value: string) => {
      const trimmed = value.trim();
      if (!trimmed) {
        return { error: "" };
      }

      const github = normalizeGitHubPath(trimmed);
      if (github) {
        return { source: github };
      }

      if (isGenericGitUrl(trimmed)) {
        return { source: trimmed.replace(/\/+$/g, "") };
      }

      return {
        error: "Enter a GitHub repo URL, owner/repo shorthand, or a full Git URL."
      };
    };

    const render = () => {
      const rawValue = sourceInput instanceof HTMLInputElement ? sourceInput.value : "";
      const adapter = adapterSelect instanceof HTMLSelectElement ? adapterSelect.value : "";
      const result = getNormalizedSource(rawValue);

      if (!(preview instanceof HTMLElement) || !(output instanceof HTMLElement) || !(error instanceof HTMLElement)) {
        return;
      }

      if (!rawValue.trim()) {
        output.hidden = true;
        error.hidden = true;
        error.textContent = "";
        return;
      }

      if (result.error) {
        output.hidden = true;
        error.hidden = false;
        error.textContent = result.error;
        return;
      }

      const adapterFlag = adapter ? ` --adapter ${adapter}` : "";
      preview.textContent = `nodus add ${result.source}${adapterFlag}`;
      output.hidden = false;
      error.hidden = true;
      error.textContent = "";
    };

    const copyCommand = async () => {
      if (!(preview instanceof HTMLElement) || !(copyButton instanceof HTMLButtonElement)) {
        return;
      }

      try {
        await navigator.clipboard.writeText(preview.textContent ?? "");
        copyButton.textContent = "Copied";
        window.setTimeout(() => {
          copyButton.textContent = "Copy";
        }, 1200);
      } catch {
        copyButton.textContent = "Copy failed";
        window.setTimeout(() => {
          copyButton.textContent = "Copy";
        }, 1200);
      }
    };

    sourceInput?.addEventListener("input", render);
    adapterSelect?.addEventListener("change", render);
    copyButton?.addEventListener("click", copyCommand);
    render();
  </script>
</SiteLayout>
